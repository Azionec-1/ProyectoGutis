generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String?
  role         UserRole @default(USER)
  workerId     String?  @unique
  isApproved   Boolean  @default(false)
  approvedAt   DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  worker       Worker?  @relation(fields: [workerId], references: [id])
}

enum UserRole {
  USER
  ADMIN
  WORKER
}

model Client {
  id              String              @id @default(cuid())
  code            String              @unique
  fullName        String
  phone           String
  address         String
  district        String
  referenceNote   String?
  googleMapsUrl   String?
  facadePhotoUrl  String?
  isActive        Boolean             @default(true)
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  sales           Sale[]
  salePayments    SalePayment[]
  inventoryEvents InventoryMovement[]
}

model Worker {
  id              String              @id @default(cuid())
  fullName        String
  phone           String
  documentId      String              @unique
  vehicleNote     String?
  isActive        Boolean             @default(true)
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  sales           Sale[]
  salePayments    SalePayment[]
  inventoryEvents InventoryMovement[]
  user            User?
}

model Sale {
  id                 String              @id @default(cuid())
  clientId           String
  workerId           String?
  status             SaleStatus          @default(PENDIENTE)
  operationType      SaleOperationType   @default(VENTA)
  paymentMethod      PaymentMethod
  paymentStatus      PaymentStatus       @default(PAGADO)
  scheduledAt        DateTime
  deliveredAt        DateTime?
  dueDate            DateTime?
  settledAt          DateTime?
  discountAmount     Decimal             @default(0)
  subtotalAmount     Decimal
  totalAmount        Decimal
  amountPaid         Decimal             @default(0)
  amountDue          Decimal             @default(0)
  notes              String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  client             Client              @relation(fields: [clientId], references: [id])
  worker             Worker?             @relation(fields: [workerId], references: [id])
  items              SaleItem[]
  payments           SalePayment[]
  inventoryMovements InventoryMovement[]
}

model SalePayment {
  id            String        @id @default(cuid())
  saleId        String
  clientId      String
  workerId      String?
  amount        Decimal
  paymentMethod PaymentMethod
  paidAt        DateTime
  note          String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  sale          Sale          @relation(fields: [saleId], references: [id], onDelete: Cascade)
  client        Client        @relation(fields: [clientId], references: [id])
  worker        Worker?       @relation(fields: [workerId], references: [id])

  @@index([saleId, paidAt])
  @@index([clientId, paidAt])
}

model SaleItem {
  id         String   @id @default(cuid())
  saleId     String
  productId  String
  quantity   Int
  unitPrice  Decimal
  totalPrice Decimal
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  sale       Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)
  product    Product  @relation(fields: [productId], references: [id])
}

model InventoryMovement {
  id           String       @id @default(cuid())
  movementType MovementType
  quantity     Int
  note         String?
  happenedAt   DateTime
  clientId     String?
  workerId     String?
  saleId       String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  client       Client?      @relation(fields: [clientId], references: [id])
  worker       Worker?      @relation(fields: [workerId], references: [id])
  sale         Sale?        @relation(fields: [saleId], references: [id])
}

model Product {
  id             String          @id @default(cuid())
  name           String
  price          Decimal
  stock          Int             @default(0)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  saleItems      SaleItem[]
  productionLogs ProductionLog[]
}

model InventorySupply {
  id                         String                    @id @default(cuid())
  name                       String                    @unique
  unitLabel                  String                    @default("unidades")
  stock                      Decimal                   @default(0)
  packageSize                Decimal?
  productionConsumptionRate  Decimal                   @default(0)
  lowStockAlert              Decimal                   @default(0)
  isActive                   Boolean                   @default(true)
  createdAt                  DateTime                  @default(now())
  updatedAt                  DateTime                  @updatedAt
  movements                  InventorySupplyMovement[]
}

model InventorySupplyMovement {
  id           String                      @id @default(cuid())
  supplyId     String
  movementType InventorySupplyMovementType
  quantity     Decimal
  stockAfter   Decimal
  note         String?
  happenedAt   DateTime
  createdAt    DateTime                    @default(now())
  updatedAt    DateTime                    @updatedAt
  supply       InventorySupply             @relation(fields: [supplyId], references: [id], onDelete: Cascade)

  @@index([supplyId, happenedAt])
  @@index([movementType, happenedAt])
}

model ProductionLog {
  id                   String   @id @default(cuid())
  productId            String
  quantity             Int
  lastRegisteredAmount Int      @default(0)
  producedOn           DateTime
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  product              Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, producedOn])
  @@index([producedOn])
}

enum SaleStatus {
  PENDIENTE
  ASIGNADO
  ENVIADO
  CANCELADO
}

enum PaymentMethod {
  EFECTIVO
  TRANSFERENCIA
  YAPE_PLIN
  CARD
}

enum PaymentStatus {
  PAGADO
  PARCIAL
  CREDITO
}

enum SaleOperationType {
  VENTA
  RECARGA
}

enum MovementType {
  INGRESO_PRODUCCION
  SALIDA_VENTA
  SALIDA_PRESTAMO
  DEVOLUCION_ENTRADA
  AJUSTE
}

enum InventorySupplyMovementType {
  INGRESO
  SALIDA
  CONSUMO_PRODUCCION
  REPOSICION_PRODUCCION
  AJUSTE
}

model ReportTemplate {
  id        String   @id @default(cuid())
  name      String
  startDate DateTime
  endDate   DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  metadata  Json?
}
